# Copy this to .env.local for local development (optional - only needed if not using Vite proxy)
# For Vercel deployment, set this in Vercel Dashboard → Settings → Environment Variables

VITE_API_URL=https://your-backend.onrender.com

# Gemini AI Integration (required for AI chat feature with Gemini)
# Get your API key from: https://makersuite.google.com/app/apikey
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI / ChatGPT Integration (required for AI chat feature with ChatGPT)
# Get your API key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here
