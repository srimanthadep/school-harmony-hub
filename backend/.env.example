# MongoDB connection string (from MongoDB Atlas)
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# JWT settings
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRE=7d

# Server
PORT=5000
NODE_ENV=development

# Comma-separated list of allowed frontend origins (overrides built-in whitelist in production)
# FRONTEND_URL=https://oxfordschool.cc,https://www.oxfordschool.cc,https://admin.oxfordschool.cc
